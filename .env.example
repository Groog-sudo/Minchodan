# Minchodan 환경변수 템플릿
# 이 파일을 복사해 .env 로 만든 뒤 실제 값을 채우십시오.
# .env 파일은 절대 커밋하지 마십시오.

# --- LLM / Ollama ---
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
GEMMA_MODEL=gemma2:9b
LLAVA_MODEL=llava
EMBEDDING_MODEL=nomic-embed-text

# OpenAI 전환 시 (LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# --- Vector DB (ChromaDB) ---
CHROMA_PATH=data/chroma_db
CHROMA_COLLECTION=bidding_kb

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- WebSocket 서버 ---
WS_HOST=0.0.0.0
WS_PORT=8000

# --- 탐지 설정 ---
DETECTOR_TYPE=mock
YOLO_CONF=0.35
FRAME_SIZE=640
REFLEX_FPS=10
COGNITIVE_FPS=2

# --- 모델 가중치 경로 (git-ignore) ---
YOLO26N_OBJECT_DET=server/models/yolo26n/object_detection.pt
YOLO26N_SEG=server/models/yolo26n/segmentation.pt

# --- TTS ---
TTS_ENGINE=kokoro
# TTS_ENGINE=coqui

# --- 데이터 경로 ---
DATA_RAW=data/raw
DATA_FRAMES=data/frames
DATA_DEDUPED=data/deduped
DATA_CAPTIONS=data/captions
DATA_REFLEX_CLIPS=data/reflex_clips

# --- 학습 환경 검증 (v1.1 C3) ---
# Blackwell sm_120 / CUDA 12.8 + cu128 PyTorch 휠 필수
# python scripts/verify_gpu.py 로 device_capability >= (12,0) 검증

# --- Slack Integration ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C0BCZSB5TJS

